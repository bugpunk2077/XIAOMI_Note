<!--
  Android 颜色选择器（Color Selector）
  作用：统一设置控件在所有状态下的颜色（无状态区分）
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
  <!--
    默认状态：所有交互状态下均使用此颜色
    #50000000：半透明黑色（透明度 50% + 纯黑）
  -->
  <item android:color="#50000000" />
</selector>